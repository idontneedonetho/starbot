# Discord
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-application-id-here

# LLM provider (pi-coding-agent supports anthropic, openai, google, and more)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-5

# Optional: Cheaper model for memory operations (extraction/compression)
# If not set, uses the main model for everything
# CHEAP_LLM_PROVIDER=anthropic
# CHEAP_LLM_MODEL=claude-haiku-3-5

# Repo settings (defaults are fine for most users)
REPO_NAME=StarPilot
REPO_DESC=a custom fork of comma.ai's openpilot driving assistance system with special support for GM vehicles
# STARPILOT_REPO_URL=https://github.com/firestar5683/starpilot
# STARPILOT_BRANCH=StarPilot
# REPO_CACHE_DIR=./repo-cache/starpilot
# SESSION_DIR=./data/sessions

# Schedule for syncing the repo (cron expression, default: every hour)
# SYNC_CRON=0 * * * *

# Seconds before an agent answer times out (default: 90)
# ANSWER_TIMEOUT_SECONDS=90

# Optional: comma-separated Discord channel IDs to restrict the bot to.
# Leave empty to allow all channels.
# ALLOWED_CHANNEL_IDS=123456789012345678,987654321098765432

# Optional: comma-separated Discord user IDs that can create new capabilities
# ADMIN_USER_IDS=123456789012345678,987654321098765432

# Plugin system settings (optional)
# PLUGINS_DIR=./data/plugins
# PLUGINS_TESTS_DIR=./tests/plugins
# PLUGIN_MAX_RETRIES=5
# PLUGIN_TIMEOUT_SECONDS=90

# Rate limiting (optional)
# RATE_LIMIT_WINDOW_SEC=60
# RATE_LIMIT_MAX=3
# MAX_CONCURRENT=2

# Memory system (optional)
# SESSION_MAX_AGE_DAYS=30
# DB_PATH=./data/memories.db
# MAX_FACTS=5
# MIN_CONFIDENCE=3

# Repo sync settings (optional)
# STALE_THRESHOLD_MS=7200000
# SYNC_MAX_RETRIES=3
# SYNC_RETRY_DELAY_MS=5000
